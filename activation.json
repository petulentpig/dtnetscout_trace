{
	"enabled": true,
	"description": "dynatracedev activation",
	"version": "0.1.0",
	"activationContext": "REMOTE",
	"pythonRemote": {
		"otlp_endpoint": "",
		"otlp_api_token": "{{otlpToken}}",
		"service_name": "netscout",
		"endpoints": [
			{
				"name": "lab-ngenius",
				"base_url": "https://ngenius.example.local",
				"records_path": "/api/v1/network-transactions",
				"records_json_path": "data",
				"netscout_api_token": "{{netscoutToken}}",
				"verify_tls": false,
				"lookback_seconds": 120,
				"traceparent_field": "traceparent",
				"start_time_field": "start_time_ms",
				"end_time_field": "end_time_ms",
				"time_format": "epoch_ms",
				"span_name_field": "transaction_name",
				"span_name_default": "netscout.network",
				"attribute_fields": "src_ip,dst_ip,dst_port,retransmissions,network_rtt_ms,packet_loss_pct,app_response_time_ms"
			}
		]
	}
}
